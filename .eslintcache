rt SkeltElement from '../Skelton/skeltonelement'\r\nimport UserSketlon from '../Skelton/UserSketlon'\r\n\r\nconst User = () => {\r\n\r\n    const [existe, setExiste] = useState(false)\r\n   useEffect(()=> {\r\n        setTimeout(async () => {\r\n            setExiste(true)\r\n        },5000)\r\n    })\r\n\r\n    return(\r\n        <div className='User'>\r\n            <h2>User</h2>\r\n           {existe && (\r\n                <div>\r\n                    <h3>Berkane Chamseddine</h3>\r\n                    <p>Etudiant en ESI</p>\r\n                    <a href='ChamsouBr'>ChamsouBr</a>\r\n                </div>\r\n            )}\r\n            {!existe && (\r\n                <UserSketlon theme='Dark' />\r\n            )}\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default User","C:\\Users\\chamsou\\Desktop\\projects_Dev\\chmsou.websites\\react_app\\skelton\\src\\componenets\\Articles.js",["58"],"import react, { useEffect, useState } from 'react'\r\nimport ArticleSkelton from '../Skelton/ArticleSkelton'\r\n\r\nconst Articles = () => {\r\n\r\n    const [existe, setExiste] = useState(false)\r\n    const varMap = [1,2,3,4,5]\r\n  useEffect(()=> {\r\n        setTimeout(async () => {\r\n              setExiste(true)\r\n        },5000)\r\n    })\r\n\r\n    return(\r\n        <div className='Articles'>\r\n            <h2>Articles</h2>\r\n            {existe && varMap.map(n=> (\r\n                <div className='Article' key={n}>\r\n                    <h3>Article N {n}</h3>\r\n                    <p>it's a time to describe our project in ESMS </p>\r\n                    <a href='ChamsouBr'>ESMS 14</a>\r\n                </div>\r\n            ))} \r\n            {!existe && varMap.map(n => (\r\n                <div className='Article'>\r\n                    <ArticleSkelton theme='Dark'/>\r\n                </div>\r\n            ))\r\n\r\n            }\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Articles","C:\\Users\\chamsou\\Desktop\\projects_Dev\\chmsou.websites\\react_app\\skelton\\src\\Skelton\\skeltonelement.js",["59"],"import react from 'react';\r\nimport './skelton.css'\r\n\r\n\r\nconst SkeltElement = ({type}) => {\r\n    const classes = `Skelton ${type}`;\r\n\r\n    return(\r\n        <div className={classes}>\r\n\r\n        </div>\r\n    )\r\n} \r\nexport default SkeltElement","C:\\Users\\chamsou\\Desktop\\projects_Dev\\chmsou.websites\\react_app\\skelton\\src\\Skelton\\ArticleSkelton.js",["60"],"import react from 'react'\r\nimport SkeltElement from './skeltonelement'\r\n\r\nconst ArticleSkelton = ({theme}) => {\r\n    const classes = `ArticleSketlon ${theme}` ;\r\n    return(\r\n        <div className={classes}>\r\n        <div className='ArticleSketlonAbsolute'></div>\r\n            <SkeltElement type='title'/>\r\n            <SkeltElement type='text' />\r\n            <SkeltElement type='text' />\r\n            <SkeltElement type='text' />\r\n        </div>\r\n    )\r\n} \r\nexport default ArticleSkelton ","C:\\Users\\chamsou\\Desktop\\projects_Dev\\chmsou.websites\\react_app\\skelton\\src\\Skelton\\UserSketlon.js",["61"],"import react from 'react'\r\nimport SkeltElement from './skeltonelement'\r\n\r\nconst UserSketlon = ({theme}) => {\r\n    const classes = `UserSketlon ${theme}`\r\n    return(\r\n        <div className={classes}>\r\n         <div className='userSketlonAbsolute'></div>\r\n          <SkeltElement type='avatar' />\r\n          <div>\r\n              <SkeltElement type='title'/>\r\n              <SkeltElement type='text' />\r\n              <SkeltElement type='text' /> \r\n          </div>\r\n        </div>\r\n    )\r\n} \r\nexport default UserSketlon ","C:\\Users\\chamsou\\Desktop\\projects_Dev\\chmsou.websites\\react_app\\skelton\\src\\AppQuery.js",["62","63"],"import react from \"react\";\r\nimport {QueryClient, QueryClientProvider, useQuery} from 'react-query'\r\nimport Navbar from \"./ComponenetQuery/navbar\";\r\nimport Plantes from \"./ComponenetQuery/Planets\";\r\n\r\n\r\nconst AppQuery = () => {\r\n\r\nconst queryClient = new QueryClient();\r\n    return(\r\n        <div className='AppQuery'>\r\n            <Navbar />\r\n            <QueryClientProvider client={queryClient} >\r\n                <Plantes />\r\n            </QueryClientProvider>\r\n        </div>\r\n    )\r\n}\r\nexport default AppQuery","C:\\Users\\chamsou\\Desktop\\projects_Dev\\chmsou.websites\\react_app\\skelton\\src\\ComponenetQuery\\navbar.js",[],"C:\\Users\\chamsou\\Desktop\\projects_Dev\\chmsou.websites\\react_app\\skelton\\src\\ComponenetQuery\\Planets.js",["64"],"C:\\Users\\chamsou\\Desktop\\projects_Dev\\chmsou.websites\\react_app\\skelton\\src\\ComponenetQuery\\Planet.js",[],{"ruleId":"65","severity":1,"message":"66","line":4,"column":8,"nodeType":"67","messageId":"68","endLine":4,"endColumn":11},{"ruleId":"69","replacedBy":"70"},{"ruleId":"71","replacedBy":"72"},{"ruleId":"65","severity":1,"message":"73","line":1,"column":8,"nodeType":"67","messageId":"68","endLine":1,"endColumn":13},{"ruleId":"65","severity":1,"message":"74","line":2,"column":8,"nodeType":"67","messageId":"68","endLine":2,"endColumn":20},{"ruleId":"65","severity":1,"message":"73","line":1,"column":8,"nodeType":"67","messageId":"68","endLine":1,"endColumn":13},{"ruleId":"65","severity":1,"message":"73","line":1,"column":8,"nodeType":"67","messageId":"68","endLine":1,"endColumn":13},{"ruleId":"65","severity":1,"message":"73","line":1,"column":8,"nodeType":"67","messageId":"68","endLine":1,"endColumn":13},{"ruleId":"65","severity":1,"message":"73","line":1,"column":8,"nodeType":"67","messageId":"68","endLine":1,"endColumn":13},{"ruleId":"65","severity":1,"message":"73","line":1,"column":8,"nodeType":"67","messageId":"68","endLine":1,"endColumn":13},{"ruleId":"65","severity":1,"message":"75","line":2,"column":43,"nodeType":"67","messageId":"68","endLine":2,"endColumn":51},{"ruleId":"65","severity":1,"message":"76","line":2,"column":21,"nodeType":"67","messageId":"68","endLine":2,"endColumn":35},"no-unused-var